{
  "name": "utilbee",
  "description": "Shared utilities for reuse across Login projects",
  "homepage": "https://github.com/Login-Linjeforening-for-IT/utilbee#readme",
  "version": "1.4.4",
  "main": "./dist/src/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Login-Linjeforening-for-IT/utilbee.git"
  },
  "bugs": {
    "url": "https://github.com/Login-Linjeforening-for-IT/utilbee/issues"
  },
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:ts": "tsc --declaration",
    "build": "npm run build:clean && npm run build:ts",
    "lint": "eslint --fix ./src"
  },
  "license": "ISC",
  "author": "",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/src/index.js",
      "default": "./dist/src/server.js"
    },
    "./utils": {
      "browser": "./dist/src/utils/index.js",
      "default": "./dist/src/utils/server.js"
    },
    "./eslint": "./dist/src/eslint.js"
  },
  "peerDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "10.2.0",
    "typescript-eslint": "8.58.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
